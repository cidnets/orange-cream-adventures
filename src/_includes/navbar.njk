<div id="navbar" class="navbar">
	<input type="checkbox" id="navbar-toggle" class="navbar-toggle">
	<label for="navbar-toggle" class="hamburger">
		<img src="/assets/heart-start.png">Start
	</label>
	
	<div class="start-divider"></div>
  
	<div class="nav-links">
		<button id="close-all-windows"><span>×</span> Close All Windows</button>
		<div class="nav-links-container">
			{% for link in navbar_links %}
			<a href="#" class="app-launcher" data-title="{{ link.title }}" data-url="{{ link.url }}" data-id="{{ link.id }}" {{ link.title }} data-window-target="new">{{ link.title }}</a>
			{% endfor %}
		</div>
	</div>
	
	<div id="date-time" class="date-time">
		<div id="date"></div> 
		<span>|</span>
		<div id="clock" class="js-clock-display">8:10:45</div>
	</div>
	
	<div id="calendar-container" class="calendar-hidden"></div>
	
</div>

<div id="mobile-navbar" class="mobile-navbar mobile">
	<button id="mobile-back-button" class="mobile-navbar-button">
		◀
	</button>
	<button id="mobile-home-button" class="mobile-navbar-button">
		●
	</button>
	<button id="mobile-app-drawer-button" class="mobile-navbar-button">
		■
	</button>
</div>

<div id="app-drawer" class="app-drawer-container mobile">
	<div id="open-apps-list">
		</div>
	<div id="drawer-controls">
		<button id="drawer-close">Close</button>
		<button id="drawer-clear-all">Clear All</button>
	</div>
</div>

<div id="mobile-status-bar" class="mobile-status-bar mobile">
	
	<div id="mobile-date-time" class="date-time">
		<div id="mobile-clock" class="js-clock-display">8:10:45</div>
	</div>
	
	<div class="status-icons-cosmetic">
		this is the other icons
	</div>
	
</div>

